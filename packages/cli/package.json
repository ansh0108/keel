{
  "name": "keelcode",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "keel": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && cp -r ../ui/dist ./ui-dist",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist ui-dist"
  },
  "files": [
    "dist",
    "ui-dist"
  ],
  "dependencies": {
    "@keelcode/core": "workspace:*",
    "@keelcode/recorder": "workspace:*",
    "@keelcode/analyzer": "workspace:*",
    "@keelcode/server": "workspace:*",
    "commander": "^12.0.0"
  }
}
