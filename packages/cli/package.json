{
  "name": "@ansh0108/keelcode",
  "version": "0.1.1",
  "bin": {
    "keel": "dist/bin.js"
  },
  "scripts": {
    "build": "node build.mjs && rm -rf ui-dist && cp -r ../ui/dist ui-dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
