  },
  "files": [
    "dist",
    "ui-dist"
  ],
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@keelcode/analyzer": "workspace:*",
    "@keelcode/core": "workspace:*",
    "@keelcode/recorder": "workspace:*",
    "@keelcode/server": "workspace:*",
    "commander": "^12.0.0",
    "esbuild": "^0.28.0"
  }
}
